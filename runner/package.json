{
  "name": "specd-runner",
  "version": "0.2.1",
  "description": "Specd Runner — Electron desktop app for autonomous agent orchestration",
  "type": "module",
  "main": "main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:renderer": "cd renderer && npm install && npm run build",
    "dist": "npm run build:renderer && electron-builder",
    "dist:mac": "npm run build:renderer && electron-builder --mac",
    "dist:linux": "npm run build:renderer && electron-builder --linux",
    "dist:win": "npm run build:renderer && electron-builder --win"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.specd.runner",
    "productName": "Specd Runner",
    "directories": {
      "output": "release"
    },
    "files": [
      "main/**/*",
      "preload.js",
      "renderer/dist/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,readme.md,LICENSE,license,License}",
      "!**/node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": null
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "publish": {
      "provider": "github",
      "owner": "victorbalan",
      "repo": "specdacular"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
